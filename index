<script>
// ══════════════════════════════════════════════════════
//  ESTADO
// ══════════════════════════════════════════════════════
const S={
  docas:Array.from({length:13},(_,i)=>({id:169+i,status:'livre',dupla:null,inicio:null,pkgs:0})),
  duplas:[],          // {id,nomes,pkgs,color,inicio,fim,docaId}
  duplas_pool:[],     // duplas disponíveis (não alocadas)
  ops:[],             // operações concluídas → feed dashboard
  filteredOps:[],
  fila:[],
  meta:5000,iniciada:false,
  historico:{},desc:0,
  log:[],
  teamColors:{},cidx:0,
  motorista:null,
  empresas:['Prálog','Imediato','Hawk','Ontime'],
};
const PAL=['#e6a817','#58a6ff','#3fb950','#f85149','#bc8cff','#ffa657','#39d353','#ff7b72','#d2a8ff','#79c0ff'];

// ── persistência ──
function sv(){
  try{
    localStorage.setItem('s_docas',JSON.stringify(S.docas));
    localStorage.setItem('s_duplas',JSON.stringify(S.duplas));
    localStorage.setItem('s_pool',JSON.stringify(S.duplas_pool));
    localStorage.setItem('s_ops',JSON.stringify(S.ops));
    localStorage.setItem('s_fila',JSON.stringify(S.fila));
    localStorage.setItem('s_meta',S.meta);
    localStorage.setItem('s_ini',S.iniciada);
    localStorage.setItem('s_hist',JSON.stringify(S.historico));
    localStorage.setItem('s_desc',S.desc);
    localStorage.setItem('s_log',JSON.stringify(S.log.slice(0,60)));
    localStorage.setItem('s_colors',JSON.stringify(S.teamColors));
    localStorage.setItem('s_cidx',S.cidx);
    localStorage.setItem('s_moto',JSON.stringify(S.motorista));
    localStorage.setItem('s_emps',JSON.stringify(S.empresas));
  }catch(e){}
}
function ld(){
  try{
    const d=localStorage.getItem('s_docas');if(d)S.docas=JSON.parse(d);
    const dp=localStorage.getItem('s_duplas');if(dp)S.duplas=JSON.parse(dp);
    const pl=localStorage.getItem('s_pool');if(pl)S.duplas_pool=JSON.parse(pl);
    const ops=localStorage.getItem('s_ops');if(ops)S.ops=JSON.parse(ops);
    const fi=localStorage.getItem('s_fila');if(fi)S.fila=JSON.parse(fi);
    S.meta=parseInt(localStorage.getItem('s_meta')||'5000');
    S.iniciada=JSON.parse(localStorage.getItem('s_ini')||'false');
    const h=localStorage.getItem('s_hist');if(h)S.historico=JSON.parse(h);
    S.desc=parseInt(localStorage.getItem('s_desc')||'0');
    const lg=localStorage.getItem('s_log');if(lg)S.log=JSON.parse(lg);
    const cl=localStorage.getItem('s_colors');if(cl)S.teamColors=JSON.parse(cl);
    S.cidx=parseInt(localStorage.getItem('s_cidx')||'0');
    const mo=localStorage.getItem('s_moto');if(mo)S.motorista=JSON.parse(mo);
    const em=localStorage.getItem('s_emps');if(em&&JSON.parse(em).length)S.empresas=JSON.parse(em);
  }catch(e){}
  if(!S.ops.length)S.ops=genOps();
}
function genOps(){
  const names=["Carlos & Bruna","Lucas & Fernanda","Matheus & Gabriela","Rafael & Juliana","Vinicius & Patricia","Gustavo & Sandra","Thiago & Amanda","Felipe & Renata","Ricardo & Camila","Diego & Beatriz"];
  const today=new Date().toISOString().slice(0,10);
  return names.map((n,i)=>{
    const h=13+(i%5),dur=60+Math.floor(Math.random()*90);
    const st=new Date(`${today}T${String(h).padStart(2,'0')}:${String((i*7)%60).padStart(2,'0')}`);
    const en=new Date(st.getTime()+dur*60000);
    return{id:i+1,team:n,startTime:st.toISOString(),endTime:en.toISOString(),packages:1500+Math.floor(Math.random()*800)};
  });
}

// ── helpers ──
function log(tipo,msg){const h=new Date().toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit',second:'2-digit'});S.log.unshift({tipo,msg,h});if(S.log.length>60)S.log.length=60;}
function color(t){if(!S.teamColors[t]){S.teamColors[t]=PAL[S.cidx%PAL.length];S.cidx++;}return S.teamColors[t];}
function initials(n){if(!n)return'??';const p=n.replace(/&/g,'e').split(/\s+e\s+/i).map(x=>x.trim());if(p.length>=2&&p[0]&&p[1])return(p[0][0]+p[1][0]).toUpperCase();const w=n.split(' ');if(w.length>=2)return(w[0][0]+w[w.length-1][0]).toUpperCase();return n.slice(0,2).toUpperCase();}
function fdt(d){return new Date(d).toLocaleString('pt-BR');}
function closeModal(){document.getElementById('modalOk').classList.remove('open');}
function fillEmpSels(){['mEmp','mfEmp'].forEach(id=>{const el=document.getElementById(id);if(!el)return;const cv=el.value;el.innerHTML=S.empresas.map(e=>`<option value="${e}">${e}</option>`).join('');if(cv&&S.empresas.includes(cv))el.value=cv;});}

// ── nav ──
function showScreen(id){document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));document.getElementById(id).classList.add('active');}
function showLogin(){showScreen('sc-login');}
function showMoto(){showScreen('sc-moto');M.render();}
function doLogin(){
  const u=document.getElementById('lu').value.trim();
  const p=document.getElementById('lp').value;
  const e=document.getElementById('lerr');
  if(u==='gestor'&&p==='1234'){e.style.display='none';showScreen('sc-app');G.render();D.filter('today');}
  else{e.style.display='block';}
}
function doLogout(){document.getElementById('lu').value='';document.getElementById('lp').value='';showScreen('sc-login');}
function setTab(id,btn){
  document.querySelectorAll('.ntab').forEach(b=>b.classList.remove('active'));btn.classList.add('active');
  document.getElementById('tab-gestao').style.display=id==='gestao'?'flex':'none';
  document.getElementById('tab-dash').style.display=id==='dash'?'flex':'none';
  if(id==='dash')D.filter(document.getElementById('fPeriod').value);
}

// ══════════════════════════════════════════════════════
//  CHARTS
// ══════════════════════════════════════════════════════
let CH={};
const CO={responsive:true,maintainAspectRatio:true,plugins:{legend:{display:false},tooltip:{backgroundColor:'#1c2331',borderColor:'#30363d',borderWidth:1,titleColor:'#c9d1d9',bodyColor:'#8b949e',padding:10,cornerRadius:6}},scales:{x:{ticks:{color:'#8b949e',font:{size:10}},grid:{color:'rgba(255,255,255,0.04)'}},y:{ticks:{color:'#8b949e',font:{size:10}},grid:{color:'rgba(255,255,255,0.04)'},beginAtZero:true}}};

function initCharts(){
  CH.hr=new Chart(document.getElementById('hrChart'),{type:'bar',data:{labels:Array.from({length:24},(_,i)=>`${i}h`),datasets:[{label:'Caminhões',data:Array(24).fill(0),backgroundColor:ctx=>{const v=ctx.raw||0,mx=10;return`rgba(230,168,23,${0.3+0.7*(v/mx)})`;},borderColor:'#e6a817',borderWidth:0,borderRadius:3}]},options:{...CO}});
  CH.vol=new Chart(document.getElementById('cVol'),{type:'bar',data:{labels:[],datasets:[{data:[],backgroundColor:[],borderRadius:3,borderWidth:0}]},options:{...CO,indexAxis:'y',scales:{x:{...CO.scales.x},y:{...CO.scales.y,grid:{display:false}}}}});
  CH.eff=new Chart(document.getElementById('cEff'),{type:'bar',data:{labels:[],datasets:[{data:[],backgroundColor:[],borderRadius:3,borderWidth:0}]},options:{...CO,indexAxis:'y',scales:{x:{...CO.scales.x},y:{...CO.scales.y,grid:{display:false}}}}});
  CH.trk=new Chart(document.getElementById('cTrk'),{type:'bar',data:{labels:[],datasets:[{data:[],backgroundColor:[],borderRadius:3,borderWidth:0}]},options:{...CO}});
  CH.dist=new Chart(document.getElementById('cDist'),{type:'doughnut',data:{labels:[],datasets:[{data:[],backgroundColor:[],borderWidth:2,borderColor:'#161b22',hoverBorderColor:'#1c2331'}]},options:{responsive:true,cutout:'65%',plugins:{legend:{position:'right',labels:{color:'#8b949e',font:{size:10},boxWidth:10,padding:8}},tooltip:{...CO.plugins.tooltip}}}});
  CH.line=new Chart(document.getElementById('cLine'),{type:'line',data:{labels:[],datasets:[]},options:{responsive:true,maintainAspectRatio:true,plugins:{legend:{display:false},tooltip:{...CO.plugins.tooltip}},scales:{x:{ticks:{color:'#8b949e',font:{size:10}},grid:{color:'rgba(255,255,255,0.04)'}},y:{ticks:{color:'#8b949e',font:{size:10}},grid:{color:'rgba(255,255,255,0.04)'},beginAtZero:true}},elements:{line:{tension:.4,borderWidth:2},point:{radius:3,hoverRadius:5}}}});
}

// ══════════════════════════════════════════════════════
//  G — GESTÃO
// ══════════════════════════════════════════════════════
const G={
  toggleAddDupla(){const f=document.getElementById('formDupla');f.style.display=f.style.display==='none'?'block':'none';},
  addDupla(){
    const nomes=document.getElementById('dNomes').value.trim();
    const pkgs=parseInt(document.getElementById('dPkgs').value)||0;
    if(!nomes){alert('Informe os nomes da dupla.');return;}
    const c=color(nomes);
    const d={id:Date.now(),nomes,pkgs,color:c,inicio:null,fim:null,docaId:null};
    S.duplas_pool.push(d);
    document.getElementById('dNomes').value='';document.getElementById('dPkgs').value='';
    document.getElementById('formDupla').style.display='none';
    log('reg',`Dupla "${nomes}" cadastrada (${pkgs} pacotes).`);
    sv();this.render();
  },
  setMeta(){const v=parseInt(document.getElementById('metaInput').value);if(v>0){S.meta=v;log('sys',`Meta: ${v.toLocaleString()} pac.`);sv();this.render();}},
  addMoto(){
    const nome=document.getElementById('mNome').value.trim();
    const emp=document.getElementById('mEmp').value;
    const pkgs=parseInt(document.getElementById('mPkgs').value)||0;
    if(!nome||!pkgs){alert('Preencha nome e pacotes.');return;}
    S.fila.push({id:Date.now(),nome,empresa:emp,pacotes:pkgs});
    document.getElementById('mNome').value='';document.getElementById('mPkgs').value='';
    log('reg',`${nome} (${emp}) entrou na fila.`);
    sv();this.render();
  },
  addCarreta(){
    const doca=S.docas.find(d=>d.status==='livre');
    if(!doca){alert('Nenhuma doca livre disponível.');return;}
    doca.status='carreta';doca.dupla='Carreta';doca.inicio=new Date().toISOString();
    log('sys',`Carreta alocada na Doca ${doca.id}.`);sv();this.render();
  },
  liberarDoca(id){
    const d=S.docas.find(x=>x.id===id);
    if(!d)return;
    // Se tinha dupla, registrar operação
    if(d.dupla&&d.status==='ocupada'){
      const ini=d.inicio,fim=new Date().toISOString();
      const dupObj=S.duplas.find(x=>x.docaId===id);
      S.ops.push({id:Date.now(),team:d.dupla,startTime:ini,endTime:fim,packages:d.pkgs||0});
      S.desc+=d.pkgs||0;
      const hr=new Date(ini).getHours();S.historico[hr]=(S.historico[hr]||0)+1;
      log('done',`${d.dupla} — Doca ${id} — +${(d.pkgs||0).toLocaleString()} pac.`);
      // Devolver para pool
      if(dupObj){dupObj.docaId=null;dupObj.inicio=null;dupObj.fim=null;S.duplas_pool.push(dupObj);S.duplas=S.duplas.filter(x=>x.docaId!==id);}
    } else if(d.status==='carreta'){
      log('done',`Carreta finalizada — Doca ${id}.`);
    }
    d.status='livre';d.dupla=null;d.inicio=null;d.pkgs=0;
    sv();this.render();D.filter(document.getElementById('fPeriod').value);
  },
  // Drag-and-drop
  setupDragDrop(){
    // Pool items são draggable
    const items=document.querySelectorAll('.dupla-item');
    items.forEach(item=>{
      item.addEventListener('dragstart',e=>{e.dataTransfer.setData('dupla-id',item.dataset.id);item.classList.add('dragging');});
      item.addEventListener('dragend',e=>{item.classList.remove('dragging');});
    });
    // Docas são drop targets
    const docas=document.querySelectorAll('.doca[data-livre="true"]');
    docas.forEach(doca=>{
      doca.addEventListener('dragover',e=>{e.preventDefault();doca.classList.add('over');});
      doca.addEventListener('dragleave',e=>{doca.classList.remove('over');});
      doca.addEventListener('drop',e=>{
        e.preventDefault();doca.classList.remove('over');
        const did=e.dataTransfer.getData('dupla-id');
        const docaId=parseInt(doca.dataset.docaId);
        G.alocarDupla(did,docaId);
      });
    });
  },
  alocarDupla(duplaId,docaId){
    const doca=S.docas.find(d=>d.id===docaId);
    const dupIdx=S.duplas_pool.findIndex(d=>String(d.id)===String(duplaId));
    if(!doca||dupIdx<0||doca.status!=='livre')return;
    const dup=S.duplas_pool.splice(dupIdx,1)[0];
    dup.docaId=docaId;dup.inicio=new Date().toISOString();
    S.duplas.push(dup);
    doca.status='ocupada';doca.dupla=dup.nomes;doca.inicio=dup.inicio;doca.pkgs=dup.pkgs;
    log('call',`${dup.nomes} → Doca ${docaId} (${dup.pkgs.toLocaleString()} pac.)`);
    sv();this.render();
  },
  render(){
    // KPIs
    const pct=Math.min(100,Math.round(S.desc/S.meta*100));
    document.getElementById('kDesc').textContent=S.desc.toLocaleString('pt-BR');
    document.getElementById('kAtivas').textContent=S.docas.filter(d=>d.status!=='livre').length;
    document.getElementById('kFila').textContent=S.fila.length;
    document.getElementById('kPct').textContent=pct+'%';
    document.getElementById('kPctSub').textContent=`${S.desc.toLocaleString()} / ${S.meta.toLocaleString()}`;
    document.getElementById('kBar').style.width=pct+'%';
    document.getElementById('metaInput').value=S.meta;
    // Pool de duplas
    const pool=document.getElementById('duplas-pool');
    document.getElementById('duplasCount').textContent=S.duplas_pool.length;
    if(!S.duplas_pool.length){pool.innerHTML='<div class="drag-hint">Nenhuma dupla disponível.<br>Cadastre uma nova dupla acima.</div>';}
    else{pool.innerHTML=S.duplas_pool.map(d=>`<div class="dupla-item" draggable="true" data-id="${d.id}"><div class="dupla-avatar" style="background:${d.color}">${initials(d.nomes)}</div><div><div class="dupla-name">${d.nomes}</div><div class="dupla-hint">${d.pkgs.toLocaleString()} pacotes</div></div><span style="font-size:9px;color:var(--muted)">⠿</span></div>`).join('');}
    // Docas
    const gr=document.getElementById('docasGrid');
    gr.innerHTML='';
    S.docas.forEach(d=>{
      const el=document.createElement('div');
      const livre=d.status==='livre';
      el.className='doca '+(d.status==='livre'?'livre':d.status==='carreta'?'carreta':'ocupada');
      if(livre){el.setAttribute('data-livre','true');el.setAttribute('data-doca-id',d.id);}
      const num=`<div class="doca-num">DOCA ${d.id}</div>`;
      if(d.status==='livre'){
        el.innerHTML=`${num}<div class="doca-badge db-livre">Livre</div><div class="doca-dupla" style="color:var(--muted);font-size:9px">Arraste uma dupla aqui</div><div class="drop-label">↓</div>`;
      } else if(d.status==='carreta'){
        el.innerHTML=`${num}<div class="doca-badge db-carreta">Carreta</div><div class="doca-dupla">Carreta</div><div class="doca-timer">—</div><div class="doca-actions"><button class="btn r" onclick="G.liberarDoca(${d.id})">Finalizar</button></div>`;
      } else {
        const ms=Date.now()-new Date(d.inicio).getTime();
        const h=String(Math.floor(ms/3600000)).padStart(2,'0');const m=String(Math.floor((ms%3600000)/60000)).padStart(2,'0');const s=String(Math.floor((ms%60000)/1000)).padStart(2,'0');
        const c=S.teamColors[d.dupla]||'#e6a817';
        el.innerHTML=`${num}<div class="doca-badge db-ocupada">Ativa</div><div class="doca-dupla"><span style="width:18px;height:18px;border-radius:3px;background:${c};display:inline-flex;align-items:center;justify-content:center;font-size:8px;font-weight:700;color:#000;margin-right:4px;flex-shrink:0">${initials(d.dupla)}</span>${d.dupla}</div><div class="doca-timer">${h}:${m}:${s}</div><div class="doca-pkgs">${(d.pkgs||0).toLocaleString()} pac.</div><div class="doca-actions"><button class="btn r" onclick="G.liberarDoca(${d.id})">Finalizar</button></div>`;
      }
      gr.appendChild(el);
    });
    // Setup drag after render
    setTimeout(()=>this.setupDragDrop(),0);
    // Fila
    const fw=document.getElementById('filaWrap');
    if(!S.fila.length){fw.innerHTML='<div style="padding:12px 14px;font-size:11px;color:var(--muted)">Nenhum motorista na fila.</div>';}
    else{fw.innerHTML=S.empresas.map(emp=>{const items=S.fila.filter(x=>x.empresa===emp);return`<div class="femp"><div class="femp-head">${emp}<span class="femp-cnt">${items.length}</span></div>${items.length?items.map(x=>{const pos=S.fila.findIndex(f=>f.id===x.id)+1;return`<div class="fitem"><div class="fpos">${pos}</div><div class="fnome">${x.nome}</div><div class="fpkgs">${x.pacotes.toLocaleString()}</div></div>`;}).join(''):'<div class="fitem" style="color:var(--muted)">Vazia</div>'}</div>`;}).join('');}
    // Log
    const lc=document.getElementById('logWrap');const lco={sys:'#58a6ff',reg:'#3fb950',call:'#e6a817',done:'#bc8cff',err:'#f85149'};
    lc.innerHTML=S.log.length?S.log.map(e=>`<div class="lentry"><div class="lt">${e.h}</div><div class="ld" style="background:${lco[e.tipo]||'#6e7681'}"></div><div class="lm">${e.msg}</div></div>`).join(''):'<div style="font-size:11px;color:var(--muted)">Aguardando eventos...</div>';
    // Resumo turno
    const tots=S.ops.reduce((a,o)=>a+o.packages,0);
    const tresumo=document.getElementById('turnoResumo');
    if(!S.ops.length){tresumo.innerHTML='<span style="color:var(--muted)">Nenhuma operação registrada.</span>';}
    else{const teams=[...new Set(S.ops.map(o=>o.team))];tresumo.innerHTML=`<div style="display:grid;grid-template-columns:1fr 1fr;gap:6px">${teams.map(t=>{const tOps=S.ops.filter(o=>o.team===t);const tPkgs=tOps.reduce((a,o)=>a+o.packages,0);const tH=tOps.reduce((a,o)=>a+(new Date(o.endTime)-new Date(o.startTime))/36e5,0);const eff=tH>0?(tPkgs/tH).toFixed(0):'—';const c=color(t);return`<div style="background:var(--s2);border:1px solid var(--b1);border-radius:5px;padding:7px 9px;font-size:10px"><div style="display:flex;align-items:center;gap:5px;margin-bottom:3px"><div style="width:14px;height:14px;border-radius:3px;background:${c};display:flex;align-items:center;justify-content:center;font-size:7px;font-weight:700;color:#000">${initials(t)}</div><span style="font-weight:700;color:var(--tx)">${t}</span></div><div style="color:var(--muted)">${tPkgs.toLocaleString()} pac · ${eff} p/h</div></div>`;}).join('')}</div>`;}
    // Hr chart
    CH.hr.data.datasets[0].data=Array.from({length:24},(_,i)=>S.historico[i]||0);CH.hr.update();
  }
};

// ══════════════════════════════════════════════════════
//  D — DASHBOARD
// ══════════════════════════════════════════════════════
const D={
  filter(val){
    const now=new Date(),td=new Date(now.getFullYear(),now.getMonth(),now.getDate());
    let st,en;
    switch(val){
      case'today':st=td;en=new Date(td.getTime()+864e5);break;
      case'yesterday':st=new Date(td.getTime()-864e5);en=td;break;
      case'week':st=new Date(td);st.setDate(st.getDate()-now.getDay());en=new Date(now.getTime()+864e5);break;
      case'month':st=new Date(now.getFullYear(),now.getMonth(),1);en=new Date(now.getTime()+864e5);break;
      default:S.filteredOps=[...S.ops];this.render();return;
    }
    S.filteredOps=S.ops.filter(o=>{const d=new Date(o.startTime);return d>=st&&d<en;});
    this.render();
  },
  addOp(){
    const t=document.getElementById('opTeam').value.trim();
    const s=document.getElementById('opStart').value;
    const e=document.getElementById('opEnd').value;
    const p=parseInt(document.getElementById('opPkgs').value)||0;
    if(!t||!s||!e||!p){alert('Preencha todos os campos.');return;}
    if(new Date(e)<=new Date(s)){alert('Término deve ser após o início.');return;}
    S.ops.push({id:Date.now(),team:t,startTime:new Date(s).toISOString(),endTime:new Date(e).toISOString(),packages:p});
    color(t);document.getElementById('opTeam').value='';document.getElementById('opPkgs').value='';
    sv();this.filter(document.getElementById('fPeriod').value);this.fillDL();
  },
  fillDL(){const dl=document.getElementById('teamsDL');dl.innerHTML=[...new Set(S.ops.map(o=>o.team))].map(t=>`<option value="${t}">`).join('');},
  metrics(){
    const teams=[...new Set(S.filteredOps.map(o=>o.team))];
    const m={};
    teams.forEach(t=>{const ops=S.filteredOps.filter(o=>o.team===t);const p=ops.reduce((a,o)=>a+o.packages,0);const h=ops.reduce((a,o)=>a+(new Date(o.endTime)-new Date(o.startTime))/36e5,0);m[t]={p,trucks:ops.length,h,eff:h>0?p/h:0};});
    return m;
  },
  render(){
    const m=this.metrics();const teams=Object.keys(m);const inits=teams.map(t=>initials(t));const cols=teams.map(t=>color(t));
    const tot=Object.values(m).reduce((a,x)=>a+x.p,0);
    const trk=Object.values(m).reduce((a,x)=>a+x.trucks,0);
    const avg=teams.length?Object.values(m).reduce((a,x)=>a+x.eff,0)/teams.length:0;
    document.getElementById('dTot').textContent=tot.toLocaleString('pt-BR');
    document.getElementById('dTrk').textContent=trk;
    document.getElementById('dTeams').textContent=teams.length;
    document.getElementById('dAvg').textContent=avg.toFixed(0);
    const srt=Object.entries(m).sort((a,b)=>b[1].eff-a[1].eff);
    if(srt.length>=2){document.getElementById('dFast').textContent=`▲ ${initials(srt[0][0])} ${srt[0][1].eff.toFixed(0)}p/h`;document.getElementById('dSlow').textContent=`▼ ${initials(srt[srt.length-1][0])} ${srt[srt.length-1][1].eff.toFixed(0)}p/h`;}
    else{document.getElementById('dFast').textContent='—';document.getElementById('dSlow').textContent='—';}
    // Horizontal bar charts
    const srtV=Object.entries(m).sort((a,b)=>b[1].p-a[1].p);
    const srtE=Object.entries(m).sort((a,b)=>b[1].eff-a[1].eff);
    CH.vol.data.labels=srtV.map(([t])=>initials(t));CH.vol.data.datasets[0].data=srtV.map(([,v])=>v.p);CH.vol.data.datasets[0].backgroundColor=srtV.map(([t])=>color(t)+'cc');CH.vol.update();
    CH.eff.data.labels=srtE.map(([t])=>initials(t));CH.eff.data.datasets[0].data=srtE.map(([,v])=>parseFloat(v.eff.toFixed(1)));CH.eff.data.datasets[0].backgroundColor=srtE.map(([t])=>color(t)+'cc');CH.eff.update();
    CH.trk.data.labels=inits;CH.trk.data.datasets[0].data=teams.map(t=>m[t].trucks);CH.trk.data.datasets[0].backgroundColor=cols.map(c=>c+'cc');CH.trk.update();
    CH.dist.data.labels=inits;CH.dist.data.datasets[0].data=teams.map(t=>m[t].p);CH.dist.data.datasets[0].backgroundColor=cols;CH.dist.update();
    // Line
    const hrs=Array.from({length:11},(_,i)=>`${String(i+13).padStart(2,'0')}:00`);
    const ds=teams.map(t=>({label:initials(t),data:hrs.map((_,idx)=>{const h=idx+13;return S.filteredOps.filter(o=>o.team===t&&new Date(o.endTime).getHours()<h+1).reduce((a,o)=>a+o.packages,0);}),borderColor:color(t),backgroundColor:color(t)+'22',fill:false,pointBackgroundColor:color(t)}));
    CH.line.data.labels=hrs;CH.line.data.datasets=ds;CH.line.update();
    // Custom legend linha
    document.getElementById('lineLegend').innerHTML=teams.map(t=>`<div class="ch-li"><div class="ch-sw" style="background:${color(t)}"></div><span>${initials(t)}: ${t}</span></div>`).join('');
    // Table
    const tb=document.querySelector('#opsTable tbody');
    if(!S.filteredOps.length){tb.innerHTML=`<tr><td colspan="8" style="text-align:center;color:var(--muted);padding:16px">Nenhuma operação encontrada.</td></tr>`;return;}
    const sorted=[...S.filteredOps].sort((a,b)=>new Date(b.startTime)-new Date(a.startTime));
    tb.innerHTML=sorted.map(op=>{
      const dur=(new Date(op.endTime)-new Date(op.startTime))/36e5;
      const eff=dur>0?op.packages/dur:0;
      const c=color(op.team);
      // Rating: top 25% é A, mid B, bottom C
      const allEff=Object.values(this.metrics()).map(x=>x.eff).sort((a,b)=>b-a);
      const rank=allEff.indexOf(allEff.find(e=>Math.abs(e-eff)<1));
      const rating=rank<allEff.length/3?'<span class="badge bg">A+</span>':rank<allEff.length*2/3?'<span class="badge ba">B</span>':'<span class="badge" style="background:rgba(248,81,73,.1);color:var(--red);border:1px solid rgba(248,81,73,.2)">C</span>';
      return`<tr><td><span style="width:18px;height:18px;border-radius:3px;background:${c};display:inline-flex;align-items:center;justify-content:center;font-size:8px;font-weight:700;color:#000;margin-right:6px;vertical-align:middle">${initials(op.team)}</span>${op.team}</td><td class="mono">${fdt(op.startTime)}</td><td class="mono">${fdt(op.endTime)}</td><td class="mono">${op.packages.toLocaleString('pt-BR')}</td><td>1</td><td class="mono">${dur.toFixed(2)}</td><td><span class="badge bg">${eff.toFixed(1)} p/h</span></td><td>${rating}</td></tr>`;
    }).join('');
    this.fillDL();
  },
  exportar(){const data=S.filteredOps.map(op=>{const dur=(new Date(op.endTime)-new Date(op.startTime))/36e5;return{'Dupla':op.team,'Início':fdt(op.startTime),'Término':fdt(op.endTime),'Pacotes':op.packages,'Duração(h)':dur.toFixed(2),'Eficiência':dur>0?(op.packages/dur).toFixed(1):'0'};});const ws=XLSX.utils.json_to_sheet(data);const wb=XLSX.utils.book_new();XLSX.utils.book_append_sheet(wb,ws,'Operações');XLSX.writeFile(wb,`operacoes-${new Date().toISOString().slice(0,10)}.xlsx`);},
  limpar(){document.getElementById('modalOk').classList.add('open');},
  confirmar(){S.ops=[];S.filteredOps=[];S.teamColors={};S.cidx=0;closeModal();sv();this.render();}
};

// ══════════════════════════════════════════════════════
//  M — MOTORISTA
// ══════════════════════════════════════════════════════
const M={
  addEmpresa(){
    const n=document.getElementById('mfNovaEmp').value.trim();
    if(!n)return;
    if(!S.empresas.includes(n))S.empresas.push(n);
    document.getElementById('mfNovaEmp').value='';
    fillEmpSels();sv();
    document.getElementById('mfEmp').value=n;
  },
  registrar(){
    const nome=document.getElementById('mfNome').value.trim();
    const wpp=document.getElementById('mfWpp').value.trim();
    const emp=document.getElementById('mfEmp').value;
    const pkgs=parseInt(document.getElementById('mfPkgs').value)||0;
    if(!nome||!pkgs){alert('Preencha nome e pacotes.');return;}
    const mot={id:Date.now(),nome,wpp,empresa:emp,pacotes:pkgs,status:'fila',docaId:null,ini:null};
    S.motorista=mot;
    S.fila.push({id:mot.id,nome:mot.nome,empresa:mot.empresa,pacotes:mot.pacotes});
    log('reg',`${nome} entrou na fila (portal).`);
    sv();G.render();this.render();
  },
  iniciar(){
    const m=S.motorista;if(!m||m.status!=='chamado')return;
    m.status='desc';m.ini=new Date().toISOString();
    log('sys',`${m.nome} iniciou — Doca ${m.docaId}.`);sv();this.render();
  },
  finalizar(){
    const m=S.motorista;if(!m||m.status!=='desc')return;
    m.status='fim';
    // add op from moto portal
    if(m.ini){const fim=new Date().toISOString();S.ops.push({id:Date.now(),team:m.nome+' (Motorista)',startTime:m.ini,endTime:fim,packages:m.pacotes});S.desc+=m.pacotes;const hr=new Date(m.ini).getHours();S.historico[hr]=(S.historico[hr]||0)+1;}
    log('done',`${m.nome} finalizou descarga.`);sv();G.render();this.render();
  },
  novo(){
    S.motorista=null;
    ['mfNome','mfWpp','mfPkgs'].forEach(id=>document.getElementById(id).value='');
    sv();this.render();
  },
  updTimer(){
    if(!S.motorista||S.motorista.status!=='desc')return;
    const el=document.getElementById('mTimer');if(!el)return;
    const ms=Date.now()-new Date(S.motorista.ini).getTime();
    const h=String(Math.floor(ms/3600000)).padStart(2,'0');const mi=String(Math.floor((ms%3600000)/60000)).padStart(2,'0');const s=String(Math.floor((ms%60000)/1000)).padStart(2,'0');
    el.textContent=`${h}:${mi}:${s}`;
  },
  render(){
    const m=S.motorista;
    document.getElementById('mForm').style.display=m?'none':'block';
    document.getElementById('mStatus').style.display=m?'block':'none';
    if(!m)return;
    document.getElementById('mNomeDisp').textContent=`${m.nome} · ${m.empresa} · ${m.pacotes.toLocaleString()} pacotes`;
    ['msWait','msCall','msDesc','msFim'].forEach(id=>document.getElementById(id).style.display='none');
    if(m.status==='fila'){
      document.getElementById('msWait').style.display='block';
      const pos=S.fila.findIndex(x=>x.id===m.id)+1;
      document.getElementById('mPos').textContent=pos>0?pos:'—';
    } else if(m.status==='chamado'){
      document.getElementById('msCall').style.display='block';
      document.getElementById('mDocaNum').textContent=`DOCA ${m.docaId}`;
    } else if(m.status==='desc'){
      document.getElementById('msDesc').style.display='block';this.updTimer();
    } else if(m.status==='fim'){
      document.getElementById('msFim').style.display='block';
    }
  }
};

// ══════════════════════════════════════════════════════
//  INIT
// ══════════════════════════════════════════════════════
document.addEventListener('DOMContentLoaded',()=>{
  ld();initCharts();fillEmpSels();D.fillDL();
  setInterval(()=>{document.getElementById('clock').textContent=new Date().toLocaleTimeString('pt-BR');},1000);
  setInterval(()=>{
    if(document.getElementById('sc-app').classList.contains('active'))G.render();
    if(document.getElementById('sc-moto').classList.contains('active')){M.updTimer();if(S.motorista&&S.motorista.status==='fila'){const pos=S.fila.findIndex(x=>x.id===S.motorista.id)+1;const el=document.getElementById('mPos');if(el)el.textContent=pos>0?pos:'—';}}
  },1000);
});
</script>
